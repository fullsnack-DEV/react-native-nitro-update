# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# NitroUpdate pod utilities for Swift flag sanitization
require_relative '../../node_modules/react-native-nitro-update/scripts/nitro_update_pod_utils'

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Static frameworks required for RN 0.84 + Swift AppDelegate (React_RCTAppDelegate module)
linkage = ENV['USE_FRAMEWORKS'] || 'static'
Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
use_frameworks! :linkage => linkage.to_sym

target 'NitroUpdateExample' do
  config = use_native_modules!
  # Resolve NitroUpdate's dependency on the Swift-only bundle manager (avoids C++ in app target)
  pod 'NitroUpdateBundleManager', :path => '../../node_modules/react-native-nitro-update'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Apply NitroUpdate fixes: Swift flag sanitization and C++ settings
    NitroUpdatePodUtils.apply!(installer, app_project_name: 'NitroUpdateExample')

    # Xcode 16+: SwiftUICore is not an allowed client for app targets; weak-link to avoid linker error
    app_project_path = File.join(Pod::Config.instance.installation_root, '..', 'NitroUpdateExample.xcodeproj')
    if File.exist?(app_project_path)
      app_project = Xcodeproj::Project.open(app_project_path)
      app_project.native_targets.each do |target|
        target.build_configurations.each do |config|
          flags = config.build_settings['OTHER_LDFLAGS'] || ['$(inherited)']
          flags = [flags] if flags.is_a?(String)
          unless flags.any? { |f| f.to_s.include?('SwiftUICore') }
            config.build_settings['OTHER_LDFLAGS'] = flags + ['-weak_framework', 'SwiftUICore']
          end

          # RN 0.84 prebuilt React frameworks are built without renderer debug symbols.
          # Ensure local pods don't force-enable REACT_NATIVE_DEBUG and explicitly link
          # renderer debug/support frameworks to avoid undefined symbol errors.
          cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
          cflags = [cflags] if cflags.is_a?(String)
          unless cflags.any? { |f| f.to_s.include?('-UREACT_NATIVE_DEBUG') }
            cflags << '-UREACT_NATIVE_DEBUG'
          end
          unless cflags.any? { |f| f.to_s.include?('-URN_ENABLE_DEBUG_STRING_CONVERTIBLE') }
            cflags << '-URN_ENABLE_DEBUG_STRING_CONVERTIBLE'
          end
          config.build_settings['OTHER_CFLAGS'] = cflags

          cxxflags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
          cxxflags = [cxxflags] if cxxflags.is_a?(String)
          unless cxxflags.any? { |f| f.to_s.include?('-UREACT_NATIVE_DEBUG') }
            cxxflags << '-UREACT_NATIVE_DEBUG'
          end
          unless cxxflags.any? { |f| f.to_s.include?('-URN_ENABLE_DEBUG_STRING_CONVERTIBLE') }
            cxxflags << '-URN_ENABLE_DEBUG_STRING_CONVERTIBLE'
          end
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxxflags

          %w[React_debug React_rendererdebug React_rendererconsistency React_renderercss].each do |framework_name|
            unless flags.any? { |f| f.to_s == framework_name } || flags.each_cons(2).any? { |a, b| a.to_s == '-framework' && b.to_s == framework_name }
              flags += ['-framework', framework_name]
            end
          end
          config.build_settings['OTHER_LDFLAGS'] = flags
        end
      end
      app_project.save
    end

    # Pods-NitroUpdateExample: compile dummy as Objective-C++ so C++ headers (Null.hpp) resolve
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        cflags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
        cflags = [cflags] if cflags.is_a?(String)
        unless cflags.any? { |f| f.to_s.include?('-UREACT_NATIVE_DEBUG') }
          cflags << '-UREACT_NATIVE_DEBUG'
        end
        unless cflags.any? { |f| f.to_s.include?('-URN_ENABLE_DEBUG_STRING_CONVERTIBLE') }
          cflags << '-URN_ENABLE_DEBUG_STRING_CONVERTIBLE'
        end
        config.build_settings['OTHER_CFLAGS'] = cflags

        cxxflags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || ['$(inherited)']
        cxxflags = [cxxflags] if cxxflags.is_a?(String)
        unless cxxflags.any? { |f| f.to_s.include?('-UREACT_NATIVE_DEBUG') }
          cxxflags << '-UREACT_NATIVE_DEBUG'
        end
        unless cxxflags.any? { |f| f.to_s.include?('-URN_ENABLE_DEBUG_STRING_CONVERTIBLE') }
          cxxflags << '-URN_ENABLE_DEBUG_STRING_CONVERTIBLE'
        end
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxxflags
      end

      if target.name == 'Pods-NitroUpdateExample'
        target.source_build_phase.files.each do |f|
          if f.file_ref && f.file_ref.path&.end_with?('.m')
            f.settings ||= {}
            f.settings['COMPILER_FLAGS'] = '-x objective-c++'
          end
        end
      end
    end
  end
end
