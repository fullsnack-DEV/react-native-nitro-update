{
  "name": "NitroUpdateExample",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "ota:build": "node -e \"var p=require('path');var r=require.resolve('react-native-nitro-update/package.json');var d=p.dirname(r);var c=p.join(d,'bin/cli.js');process.argv=[process.argv[0],c,'build','--platform','ios'].concat(process.argv.slice(2));require(c);\"",
    "ota:build:upload": "node -e \"var p=require('path');var r=require.resolve('react-native-nitro-update/package.json');var d=p.dirname(r);var c=p.join(d,'bin/cli.js');process.argv=[process.argv[0],c,'build','--platform','ios','--upload','s3'].concat(process.argv.slice(2));require(c);\"",
    "ota:zip": "bash scripts/build-ota-zip-ios.sh",
    "setupOTA": "node -e \"var p=require('path');var r=require.resolve('react-native-nitro-update/package.json');require(p.join(p.dirname(r),'bin/setup-ota.js'))\"",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "0.84.1",
    "@react-native/new-app-screen": "0.84.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-nitro-update": "file:../packages/react-native-nitro-update",
    "react-native-nitro-modules": "0.35.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}