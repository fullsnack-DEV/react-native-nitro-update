{
  "name": "react-native-nitro-update",
  "version": "0.0.6",
  "description": "OTA updates for React Native via Nitro/JSI: check, download, reload, rollback, checksum, retry, manifest",
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "react-native-nitro-update": "bin/cli.js",
    "setup-ota": "bin/setup-ota.js",
    "nitro-update-doctor": "bin/doctor.js"
  },
  "files": [
    "bin",
    "src",
    "lib",
    "INTEGRATION.md",
    "react-native.config.js",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "nitro.json",
    "NitroIsolatedBundle",
    "*.podspec",
    "scripts/nitro_update_pod_utils.rb",
    "scripts/run-cli.js",
    "scripts/post-nitrogen-fix.sh"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib tsconfig.tsbuildinfo",
    "lint": "eslint \"**/*.{js,ts,tsx}\" --fix",
    "lint-ci": "eslint \"**/*.{js,ts,tsx}\" -f @jamesacarr/github-actions",
    "typescript": "tsc",
    "specs": "tsc --noEmit false && nitrogen --logLevel=\"debug\" && bash scripts/post-nitrogen-fix.sh",
    "validate": "node scripts/validate-package.js",
    "prepublishOnly": "npm run typescript && bash scripts/post-nitrogen-fix.sh && npm run validate",
    "release": "npm run clean && npm run typescript && bash scripts/post-nitrogen-fix.sh && npm run validate && npm publish"
  },
  "keywords": [
    "react-native",
    "nitro",
    "ota",
    "over-the-air",
    "updates",
    "jsi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fullsnack-DEV/react-native-nitro-update.git"
  },
  "author": "fullsnack-DEV (https://github.com/fullsnack-DEV)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fullsnack-DEV/react-native-nitro-update/issues"
  },
  "homepage": "https://github.com/fullsnack-DEV/react-native-nitro-update#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "0.83.0",
    "@types/react": "^19.1.03",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "nitrogen": "*",
    "prettier": "^3.3.3",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-nitro-modules": "*",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  }
}
